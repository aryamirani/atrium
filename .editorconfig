# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs (gofmt is authoritative).
[*.go]
indent_style = tab

[go.mod]
indent_style = tab

[Makefile]
indent_style = tab

# Don't trim trailing whitespace in Markdown (two trailing spaces = hard break).
[*.md]
trim_trailing_whitespace = false
